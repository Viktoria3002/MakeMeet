<% content_for :title, "Форма регистрации - Make Meet" %>
<%= render "pages/auth_entry_head" %>

<section class="registration-section">
  <div class="registration-card auth-entry-card">
    <h1 class="registration-title">Давайте знакомиться</h1>

    <form class="registration-form" id="registrationForm" novalidate>
      <div class="registration-grid">
        <div class="registration-left">
          <input type="text" class="registration-input is-empty" id="registrationName" placeholder="Имя">
          <input type="email" class="registration-input is-empty" id="registrationEmail" placeholder="Почта">

          <div class="registration-city-box">
            <input
              type="text"
              class="registration-input registration-input--city is-empty"
              id="registrationCity"
              placeholder="Город"
              autocomplete="off"
            >
            <button type="button" class="registration-city-toggle" id="registrationCityToggle" aria-label="Открыть список городов">
              <span class="registration-city-toggle-icon"></span>
            </button>
            <div class="registration-city-dropdown" id="registrationCityDropdown"></div>
          </div>
        </div>

        <div class="registration-right">
          <div class="registration-about-wrap">
            <textarea
              class="registration-about is-empty"
              id="registrationAbout"
              placeholder="О себе"
              maxlength="400"
            ></textarea>
            <span class="registration-about-counter" id="registrationAboutCounter">0/400</span>
          </div>
        </div>
      </div>

      <div class="registration-submit-wrap">
        <button type="submit" class="auth-image-btn auth-image-btn--submit" id="registrationSubmitButton">
          <%= image_tag "Q_Button_1 (11).png", alt: "Зарегистрироваться", class: "auth-image-btn__img" %>
        </button>
      </div>

      <p class="registration-disclaimer">
        Нажимая «Зарегистрироваться», вы принимаете условия
        сервиса и даёте согласие на обработку данных.
      </p>
    </form>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('registrationForm');
    const nameInput = document.getElementById('registrationName');
    const emailInput = document.getElementById('registrationEmail');
    const cityInput = document.getElementById('registrationCity');
    const aboutInput = document.getElementById('registrationAbout');
    const counter = document.getElementById('registrationAboutCounter');
    const submitButton = document.getElementById('registrationSubmitButton');
    const dropdown = document.getElementById('registrationCityDropdown');
    const toggleButton = document.getElementById('registrationCityToggle');

    if (!form || !nameInput || !emailInput || !cityInput || !aboutInput || !counter || !submitButton || !dropdown || !toggleButton) {
      return;
    }

    const formInputs = [nameInput, emailInput, cityInput, aboutInput];

    const russianCities = [
      'Абакан', 'Азов', 'Александров', 'Алексин', 'Альметьевск', 'Анапа', 'Ангарск', 'Анжеро-Судженск',
      'Апатиты', 'Арзамас', 'Армавир', 'Архангельск', 'Асбест', 'Астрахань', 'Ачинск', 'Балаково',
      'Балашиха', 'Барнаул', 'Батайск', 'Белгород', 'Белебей', 'Белово', 'Белорецк', 'Белореченск',
      'Бердск', 'Березники', 'Березовский', 'Бийск', 'Биробиджан', 'Благовещенск', 'Бор', 'Борисоглебск',
      'Братск', 'Брянск', 'Бугульма', 'Буденновск', 'Бузулук', 'Великие Луки', 'Великий Новгород', 'Верхняя Пышма',
      'Видное', 'Владивосток', 'Владикавказ', 'Владимир', 'Волгоград', 'Волгодонск', 'Волжск', 'Волжский',
      'Вологда', 'Вольск', 'Воркута', 'Воронеж', 'Выборг', 'Выкса', 'Гатчина', 'Геленджик',
      'Георгиевск', 'Глазов', 'Горно-Алтайск', 'Грозный', 'Губкин', 'Гудермес', 'Дербент', 'Дзержинск',
      'Димитровград', 'Дмитров', 'Долгопрудный', 'Домодедово', 'Донской', 'Дубна', 'Евпатория', 'Егорьевск',
      'Ейск', 'Екатеринбург', 'Елабуга', 'Елец', 'Ессентуки', 'Железногорск', 'Жигулевск', 'Жуковский',
      'Заречный', 'Зеленогорск', 'Зеленодольск', 'Златоуст', 'Иваново', 'Ижевск', 'Избербаш', 'Иркутск',
      'Искитим', 'Ишим', 'Йошкар-Ола', 'Казань', 'Калининград', 'Калуга', 'Каменск-Уральский', 'Каменск-Шахтинский',
      'Камышин', 'Канск', 'Каспийск', 'Кемерово', 'Керчь', 'Кинешма', 'Кириши', 'Киров',
      'Кирово-Чепецк', 'Киселевск', 'Кисловодск', 'Клин', 'Клинцы', 'Ковров', 'Коломна', 'Комсомольск-на-Амуре',
      'Копейск', 'Королев', 'Кострома', 'Котлас', 'Красногорск', 'Краснодар', 'Краснокаменск', 'Краснокамск',
      'Краснотурьинск', 'Красноярск', 'Кропоткин', 'Крымск', 'Кстово', 'Кузнецк', 'Кумертау', 'Кунгур',
      'Курган', 'Курск', 'Кызыл', 'Лабинск', 'Лениногорск', 'Ленинск-Кузнецкий', 'Лесосибирск', 'Липецк',
      'Лиски', 'Лобня', 'Люберцы', 'Магадан', 'Магнитогорск', 'Майкоп', 'Махачкала', 'Междуреченск',
      'Мелеуз', 'Миасс', 'Минеральные Воды', 'Минусинск', 'Михайловка', 'Мичуринск', 'Москва', 'Мурманск',
      'Муром', 'Мытищи', 'Набережные Челны', 'Надым', 'Назарово', 'Назрань', 'Нальчик', 'Наро-Фоминск',
      'Находка', 'Невинномысск', 'Нерюнгри', 'Нефтекамск', 'Нефтеюганск', 'Нижневартовск', 'Нижнекамск', 'Нижний Новгород',
      'Нижний Тагил', 'Новоалтайск', 'Новокузнецк', 'Новокуйбышевск', 'Новомосковск', 'Новороссийск', 'Новосибирск', 'Новотроицк',
      'Новоуральск', 'Новочебоксарск', 'Новочеркасск', 'Новошахтинск', 'Новый Уренгой', 'Ногинск', 'Норильск', 'Ноябрьск',
      'Обнинск', 'Одинцово', 'Озерск', 'Октябрьский', 'Омск', 'Орел', 'Оренбург', 'Орехово-Зуево',
      'Орск', 'Павлово', 'Павловский Посад', 'Пенза', 'Первоуральск', 'Пермь', 'Петрозаводск', 'Петропавловск-Камчатский',
      'Подольск', 'Полевской', 'Прокопьевск', 'Прохладный', 'Псков', 'Пушкино', 'Пятигорск', 'Раменское',
      'Ревда', 'Реутов', 'Ржев', 'Рославль', 'Россошь', 'Ростов-на-Дону', 'Рубцовск', 'Рыбинск',
      'Рязань', 'Салават', 'Сальск', 'Самара', 'Санкт-Петербург', 'Саранск', 'Сарапул', 'Саратов',
      'Саров', 'Севастополь', 'Северодвинск', 'Северск', 'Сергиев Посад', 'Серов', 'Серпухов', 'Симферополь',
      'Смоленск', 'Соликамск', 'Солнечногорск', 'Сосновый Бор', 'Сочи', 'Ставрополь', 'Старый Оскол', 'Стерлитамак',
      'Ступино', 'Сургут', 'Сызрань', 'Сыктывкар', 'Таганрог', 'Тамбов', 'Тверь', 'Тимашевск',
      'Тихвин', 'Тихорецк', 'Тобольск', 'Тольятти', 'Томск', 'Троицк', 'Туапсе', 'Туймазы',
      'Тула', 'Тюмень', 'Узловая', 'Улан-Удэ', 'Ульяновск', 'Урус-Мартан', 'Усолье-Сибирское', 'Уссурийск',
      'Усть-Илимск', 'Уфа', 'Ухта', 'Феодосия', 'Хабаровск', 'Ханты-Мансийск', 'Хасавюрт', 'Химки',
      'Чайковский', 'Чапаевск', 'Чебаркуль', 'Чебоксары', 'Челябинск', 'Черемхово', 'Череповец', 'Черкесск',
      'Черногорск', 'Чехов', 'Чистополь', 'Чита', 'Шадринск', 'Шали', 'Шахты', 'Шуя',
      'Щекино', 'Щелково', 'Электросталь', 'Элиста', 'Энгельс', 'Южно-Сахалинск', 'Юрга', 'Якутск',
      'Ялта', 'Ярославль'
    ];

    function updateCounter() {
      counter.textContent = aboutInput.value.length + '/400';
    }

    function isFormValid() {
      return Boolean(
        nameInput.value.trim() &&
        emailInput.value.trim() &&
        cityInput.value.trim() &&
        aboutInput.value.trim()
      );
    }

    function updateInputStates() {
      formInputs.forEach(function(input) {
        const value = input.type === 'password' ? input.value : input.value.trim();
        const filled = value.length > 0;
        input.classList.toggle('is-filled', filled);
        input.classList.toggle('is-empty', !filled);
      });
    }

    function bindInputStates() {
      formInputs.forEach(function(input) {
        function refresh() {
          updateInputStates();
        }

        ['input', 'change', 'blur', 'focus'].forEach(function(eventName) {
          input.addEventListener(eventName, refresh);
        });
      });
    }

    function renderCityOptions(query) {
      const normalizedQuery = query.trim().toLowerCase();
      dropdown.innerHTML = '';

      if (!normalizedQuery) {
        dropdown.classList.remove('is-open');
        return;
      }

      const matches = russianCities
        .filter((city) => city.toLowerCase().startsWith(normalizedQuery))
        .slice(0, 8);

      if (!matches.length) {
        dropdown.classList.remove('is-open');
        return;
      }

      matches.forEach((city) => {
        const option = document.createElement('button');
        option.type = 'button';
        option.className = 'registration-city-option';
        option.textContent = city;
        option.addEventListener('click', function() {
          cityInput.value = city;
          dropdown.classList.remove('is-open');
          updateInputStates();
        });
        dropdown.appendChild(option);
      });

      dropdown.classList.add('is-open');
    }

    formInputs.forEach(function(input) {
      input.addEventListener('input', function() {
        if (input === aboutInput) {
          updateCounter();
        }

        if (input === cityInput) {
          renderCityOptions(cityInput.value);
        }
      });
    });

    bindInputStates();

    document.addEventListener('animationstart', function(event) {
      if (event.animationName !== 'authInputAutofillStart') return;
      if (!event.target.classList.contains('registration-input') && !event.target.classList.contains('registration-about')) return;
      updateInputStates();
    }, true);

    window.setTimeout(updateInputStates, 150);

    cityInput.addEventListener('focus', function() {
      renderCityOptions(cityInput.value);
    });

    toggleButton.addEventListener('click', function() {
      renderCityOptions(cityInput.value || 'а');
      cityInput.focus();
    });

    document.addEventListener('click', function(event) {
      if (!event.target.closest('.registration-city-box')) {
        dropdown.classList.remove('is-open');
      }
    });

    form.addEventListener('submit', function(event) {
      event.preventDefault();

      if (!isFormValid()) {
        updateInputStates();
        return;
      }

      updateInputStates();
      window.localStorage.setItem('makeMeetUserLoggedIn', 'true');
      window.localStorage.setItem('makeMeetUserEmail', emailInput.value.trim());
      window.location.href = '<%= auth_welcome_path %>';
    });

    updateCounter();
    updateInputStates();
  });
</script>
