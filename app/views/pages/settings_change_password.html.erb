<% content_for :title, "Изменить пароль - Make Meet" %>

<% content_for :head do %>
  <style>
    body.settings-change-password-page {
      background-image: url('<%= asset_path("bg_settings.png") %>');
      background-position: center center;
      background-repeat: no-repeat;
      background-size: cover;
      background-attachment: fixed;
      min-height: 100vh;
      overflow-x: hidden;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    }

    body.settings-change-password-page .main-navigation {
      position: relative;
      z-index: 1001;
      margin-bottom: 0;
    }

    body.settings-change-password-page .main-content {
      padding: 0;
      max-width: none;
    }

    body.settings-change-password-page .main-navigation .nav-container {
      background: rgba(255, 255, 255, 0.3);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-color: rgba(255, 255, 255, 0.4);
    }

    body.settings-change-password-page .nav-link {
      color: #ffffff;
    }

    body.settings-change-password-page .main-footer {
      display: none;
    }
  </style>
<% end %>

<section class="settings-change-password-section">
  <div class="settings-change-password-wrap">
    <%= link_to settings_path, class: "settings-change-password-back" do %>
      <span class="settings-change-password-back-chevron" aria-hidden="true"></span>
      <span>Настройки</span>
    <% end %>

    <div class="settings-change-password-card auth-entry-card">
      <h1 class="settings-change-password-title">Изменить пароль</h1>
      <p class="settings-change-password-description">Восстановите пароль, если забыли или поменяйте на более сложный</p>

      <form class="settings-change-password-form" id="settingsChangePasswordForm" novalidate>
        <input type="password" class="login-input is-empty" id="settingsOldPassword" placeholder="Старый пароль" autocomplete="current-password">
        <input type="password" class="login-input is-empty" id="settingsNewPassword" placeholder="Новый пароль" autocomplete="new-password">

        <div class="login-submit-wrap login-submit-wrap--recovery">
          <button type="submit" class="auth-image-btn auth-image-btn--submit auth-image-btn--wide login-submit-btn">
            <%= image_tag "Q_Button_1 (9).png", alt: "Сменить пароль", class: "auth-image-btn__img" %>
          </button>
        </div>
      </form>
    </div>
  </div>
</section>

<script>
  (function() {
    function initSettingsChangePasswordPage() {
      const form = document.getElementById('settingsChangePasswordForm');
      const oldPasswordInput = document.getElementById('settingsOldPassword');
      const newPasswordInput = document.getElementById('settingsNewPassword');
      if (!form || form.dataset.bound === 'true') return;
      form.dataset.bound = 'true';

      const inputs = form.querySelectorAll('.login-input');

      function updateInputStates() {
        inputs.forEach(function(input) {
          const value = input.value;
          const filled = value.length > 0;
          input.classList.toggle('is-filled', filled);
          input.classList.toggle('is-empty', !filled);
        });
      }

      inputs.forEach(function(input) {
        input.addEventListener('input', updateInputStates);
        input.addEventListener('change', updateInputStates);
      });

      form.addEventListener('submit', function(event) {
        event.preventDefault();

        const newPassword = newPasswordInput.value;
        if (newPassword) {
          window.localStorage.setItem('makeMeetUserPassword', newPassword);
        }

        window.location.href = '<%= settings_path %>?password_sent=1';
      });

      updateInputStates();
    }

    document.addEventListener('DOMContentLoaded', initSettingsChangePasswordPage);
    document.addEventListener('turbo:load', initSettingsChangePasswordPage);
    document.addEventListener('turbo:render', initSettingsChangePasswordPage);
  })();
</script>
