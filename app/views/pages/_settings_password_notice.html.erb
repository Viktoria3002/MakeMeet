<div class="settings-notice is-hidden" id="settingsPasswordNotice" aria-hidden="true">
  <button type="button" class="settings-notice__backdrop" id="settingsPasswordNoticeBackdrop" aria-label="Закрыть уведомление"></button>

  <div class="settings-notice__card auth-entry-card" role="dialog" aria-modal="true" aria-labelledby="settingsPasswordNoticeTitle">
    <div class="settings-notice__icon-wrap">
      <%= image_tag "Q_Telegram.png", alt: "", class: "settings-notice__icon", aria: { hidden: true } %>
    </div>

    <h2 class="settings-notice__title" id="settingsPasswordNoticeTitle">Отправили на почту</h2>
    <p class="settings-notice__text">Информацию о смене пароля, по ссылке вам будет доступна эта функция</p>
  </div>
</div>
