<% content_for :title, "Профиль - Make Meet" %>
<% content_for :head do %>
  <style>
    body.profile-page {
      background-image: url('<%= asset_path("bgprofile.png") %>');
      background-position: center;
      background-repeat: no-repeat;
      background-size: cover;
      background-attachment: fixed;
    }
  </style>
<% end %>

<section class="profile-page-section">
  <div class="profile-page-content">
    <div class="profile-author-card">
      <%= image_tag "autor.png", alt: "Профиль пользователя", class: "profile-author-image" %>
    </div>

    <div class="profile-actions">
      <button type="button" class="profile-action-button">
        <%= image_tag "Q_Button_1 (1).png", alt: "Настройки", class: "profile-action-image" %>
      </button>
      <%= link_to profile_details_path, class: "profile-action-button" do %>
        <%= image_tag "Q_Button_1 (2).png", alt: "Профиль", class: "profile-action-image" %>
      <% end %>
    </div>

    <div class="profile-legal">
      <p>Версия веб-сервиса: 1.0</p>
      <p class="profile-legal-link">Согласие на обработку персональных данных</p>
      <p class="profile-legal-link">Пользовательское соглашение</p>
      <p class="profile-legal-link">Политика обработки персональных данных</p>
    </div>
  </div>
</section>
