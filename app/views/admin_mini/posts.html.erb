<section class="admin-mini-page">
  <div class="admin-mini-card">
    <div class="admin-mini-toolbar">
      <h1 class="admin-mini-title">Admin Mini App</h1>
      <div class="admin-mini-actions">
        <%= link_to "Перейти в админку", admin_root_path, class: "admin-mini-link admin-mini-link--secondary" %>
        <button type="button" class="admin-mini-button admin-mini-button--secondary" onclick="logout()">Logout</button>
      </div>
    </div>

    <div class="admin-mini-create">
      <textarea id="content" class="admin-mini-input admin-mini-textarea" placeholder="Текст поста"></textarea>
      <button type="button" class="admin-mini-button" onclick="createPostAPI()">Создать пост</button>
    </div>

    <h2 class="admin-mini-section-title">Посты</h2>

    <ul id="posts-list" class="admin-mini-posts"></ul>
  </div>
</section>