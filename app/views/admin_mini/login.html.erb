<section class="admin-mini-page">
  <div class="admin-mini-card admin-mini-card--auth">
    <h1 class="admin-mini-title">Admin Mini App Login</h1>

    <div class="admin-mini-form">
      <input id="email" class="admin-mini-input" placeholder="Email">
      <input id="password" class="admin-mini-input" type="password" placeholder="Password">
      <button type="button" class="admin-mini-button" onclick="login()">Login</button>
    </div>
  </div>
</section>

<script>
async function login() {
  const email = document.getElementById("email").value
  const password = document.getElementById("password").value

  const res = await fetch("/api/login", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({ email, password })
  })

  const data = await res.json()
  console.log(data)

  if (res.ok) {
    localStorage.setItem("token", data.token)
    window.location.href = "/admin_mini/posts"
  } else {
    alert("Ошибка входа")
  }
}
</script>