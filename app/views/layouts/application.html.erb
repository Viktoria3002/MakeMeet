<!DOCTYPE html>
<html class="<%= 'admin-page' if controller_path.include?('admin') %>">
  <head>
    <title><%= content_for(:title) || "Make Meet1" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <!-- SF Pro Display Font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= javascript_include_tag "admin_api", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body class="<%= 'about-page' if current_page?(about_path) || current_page?(root_path) %> <%= 'media-page' if current_page?(page1_path) %> <%= 'admin-page' if controller_path.include?('admin') %> <%= 'sprints-page' if current_page?(page2_path) %> <%= 'profile-page' if current_page?(page4_path) || current_page?(profile_details_path) %> <%= 'profile-details-page' if current_page?(profile_details_path) %> <%= 'register-page' if current_page?(register_path) %> <%= 'registration-page' if current_page?(registration_path) %> <%= 'login-page' if current_page?(login_path) %> <%= 'my-sprints-page' if current_page?(page3_path) %> <%= 'article-page' if current_page?(article_path) %>">
    <% if current_page?(page1_path) %>
      <div class="media-page-wrapper">
    <% end %>
    
    <% minimal_nav_pages = current_page?(register_path) || current_page?(registration_path) || current_page?(login_path) %>

    <nav class="main-navigation">
      <div class="nav-container">
        <div class="nav-brand">
          <%= link_to root_path, class: "brand-link" do %>
            <div class="logo-container">
              <%= image_tag "nav_logo.png", alt: "Make Meet", class: "nav-logo-img" %>
            </div>
          <% end %>
        </div>
        <ul class="nav-menu">
          <li class="nav-item">
            <%= link_to "О сервисе", about_path, class: "nav-link #{'active' if current_page?(about_path) || current_page?(root_path)}" %>
          </li>
          <% unless minimal_nav_pages %>
            <li class="nav-item">
              <%= link_to "Медиа", page1_path, class: "nav-link #{'active' if current_page?(page1_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Открытые спринты", page2_path, class: "nav-link #{'active' if current_page?(page2_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Мои спринты", page3_path, class: "nav-link #{'active' if current_page?(page3_path)}" %>
            </li>
            <li class="nav-item">
              <%= link_to "Профиль", page4_path, class: "nav-link #{'active' if current_page?(page4_path) || current_page?(profile_details_path)}" %>
            </li>
            <li class="nav-item nav-item--admin-hidden">
              <button class="nav-link admin-link-btn" onclick="openAdminLogin()">🔧 Админ</button>
            </li>
          <% end %>
        </ul>
      </div>
    </nav>

    <main class="main-content">
      <%= yield %>
    </main>
    
    <% if current_page?(page1_path) %>
      </div>
    <% end %>

    <% unless current_page?(page4_path) || minimal_nav_pages %>
      <footer class="main-footer">
        <div class="footer-content">
          <%= image_tag "footer_bar.svg", alt: "найди единомышленников с make Meet", class: "footer-bar-img" %>
        </div>
      </footer>
    <% end %>

    <!-- Admin Login Modal -->
    <div class="admin-login-modal" id="adminLoginModal" style="display: none;">
      <div class="admin-login-modal-backdrop" onclick="closeAdminLogin()"></div>
      <div class="admin-login-modal-content">
        <h2 class="admin-login-title">Вход в админку</h2>
        <%= form_tag admin_login_path, method: :post, class: "admin-login-form", id: "adminLoginForm" do %>
          <div class="form-group">
            <label class="form-label">Логин</label>
            <%= text_field_tag :username, nil, class: "form-input", placeholder: "Введите логин" %>
          </div>
          <div class="form-group">
            <label class="form-label">Пароль</label>
            <%= password_field_tag :password, nil, class: "form-input", placeholder: "Введите пароль" %>
          </div>
          <div id="adminLoginAlert"></div>
          <%= submit_tag "Войти", class: "admin-login-submit" %>
          <button type="button" class="admin-login-close" onclick="closeAdminLogin()">✕</button>
        <% end %>
      </div>
    </div>

    <script>
      function openAdminLogin() {
        const modal = document.getElementById('adminLoginModal');
        if (modal) {
          modal.style.display = 'flex';
          document.body.style.overflow = 'hidden';
        }
      }

      function closeAdminLogin() {
        const modal = document.getElementById('adminLoginModal');
        if (modal) {
          modal.style.display = 'none';
          document.body.style.overflow = 'auto';
        }
      }

      // Закрыть по ESC
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          closeAdminLogin();
        }
      });

      // Обработка формы
      document.addEventListener('DOMContentLoaded', function() {
        const form = document.getElementById('adminLoginForm');
        if (form) {
          form.addEventListener('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(form);
            fetch('<%= admin_login_path %>', {
              method: 'POST',
              body: formData,
              headers: {
                'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').getAttribute('content')
              }
            })
            .then(response => {
              if (response.redirected) {
                window.location.href = response.url;
              } else {
                return response.text();
              }
            })
            .catch(error => {
              console.error('Error:', error);
            });
          });
        }
      });
    </script>
  </body>
</html>
